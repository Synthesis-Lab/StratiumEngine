###############################################################################
# Satır sonu normalizasyonu
###############################################################################
* text=auto

###############################################################################
# Görüntü dosyaları binary olarak işlenir
###############################################################################
*.jpg   binary
*.png   binary
*.gif   binary
*.bmp   binary
*.tga   binary
*.dds   binary
*.ico   binary
*.svg   binary

###############################################################################
# Yaygın doküman ve veri dosyaları için diff ayarları
###############################################################################
*.md    diff=astextplain
*.txt   diff=astextplain
*.json  diff=astextplain
*.xml   diff=astextplain
*.yml   diff=astextplain
*.yaml  diff=astextplain

###############################################################################
# C++ kaynak dosyaları için diff ayarı (isteğe bağlı, kod incelemesi için faydalı)
###############################################################################
*.cpp   diff=cpp
*.h     diff=cpp
